# Copy this file to .env and update values before running in production

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=your-very-long-random-secret-key-here-change-in-production

# Database
DATABASE_URL=sqlite:////data/tessera.db

# Token expiry in minutes (480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# First admin user - created on startup if not already present
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=changeme123
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_FULL_NAME=Administrator
